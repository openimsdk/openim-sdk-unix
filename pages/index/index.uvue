				<view class="button-grid">
					<button class="action-button danger-button" @click="handleAddFriend">82 Add Friend</button>
					<button class="action-button danger-button" @click="handleUpdateFriends">83 Update Friends</button>
					<button class="action-button danger-button" @click="handleAcceptFriendApplication">84 Accept Friend App</button>
