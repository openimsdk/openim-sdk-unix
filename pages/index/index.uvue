					<button class="action-button danger-button" @click="handleDeleteAllMsgFromLocal">105 Delete All Local</button>
					<button class="action-button danger-button" @click="handleDeleteAllMsgFromLocalAndSvr">106 Delete All Server</button>
					<button class="action-button danger-button" @click="handleClearConversationAndDeleteAllMsg">107 Clear Conversation</button>
