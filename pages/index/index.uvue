<template>
	<!-- #ifdef APP -->
	<scroll-view class="page-scroll">
	<!-- #endif -->
		<view class="page">
			<text class="title">Unix OpenIM SDK</text>
			<text class="status">{{statusText}}</text>
			<text class="cache-text">{{cacheText}}</text>

			<view class="section">
				<text class="section-title">Setup</text>
				<view class="button-grid">
					<button class="action-button" @click="handleInitSDKOnly">01 Init SDK</button>
					<button class="action-button" @click="handleLoginOnly">02 Login</button>
					<button class="action-button" @click="handleLogout">03 Logout</button>
