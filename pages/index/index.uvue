		OpenIMSessionTypeSingle,
		OpenIMSetConversationDraftParams,
		OpenIMSetConversationParams,
		OpenIMSetGroupInfoParams,
		OpenIMSetGroupMemberInfoParams,
		OpenIMSetMessageLocalExParams,
		OpenIMSetSelfInfoParams,
		OpenIMSendMessageProgressEvent,
		OpenIMFriendApplicationHandleParams,
		OpenIMFriendApplicationItem,
		OpenIMFriendApplicationListResult,
		OpenIMFriendListResult,
		OpenIMFriendUserItem,
		OpenIMAddBlackParams,
		OpenIMAddFriendParams,
		OpenIMGetSpecifiedFriendsInfoParams,
		OpenIMInputStateParams,
		OpenIMSoundElem,
		OpenIMUpdateFriendsParams,
		OpenIMUpdateFcmTokenParams,
		OpenIMUploadFileParams,
		OpenIMUploadFileProgressEvent,
		OpenIMUploadFileResult,
		OpenIMUploadLogsParams,
		OpenIMUploadLogsProgressEvent,
		OpenIMUserInfo,
		OpenIMUserListResult,
		OpenIMSDKUnsubscribe,
		OpenIMMessageRevokedItem,
		OpenIMMessageReceiptListResult,
		OpenIMConversationInputStatusItem,
		OpenIMUserCommandItem,
		OpenIMUserStatusListResult,
		OpenIMVideoElem,
		OpenIMFileElem,
		OpenIMCardElem,
		onConnecting,
		onConnectSuccess,
		onConnectFailed,
		onKickedOffline,
		onUserTokenExpired,
		onUserTokenInvalid,
