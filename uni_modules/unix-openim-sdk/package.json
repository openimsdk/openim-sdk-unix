{
  "id": "unix-openim-sdk",
  "displayName": "Unix OpenIM SDK",
  "version": "0.1.1",
  "description": "OpenIM：由IM技术专家打造的基于 Go 实现的即时通讯（IM）项目，从服务端到客户端SDK开源即时通讯（IM）整体解决方案，可以轻松替代第三方IM云服务，打造具备聊天、社交功能的app。",
  "keywords": [
    "即时通讯",
    "IM",
    "uni-app-x",
    "Chat",
    "OpenIM"
],
  "license": "AGPL-3.0-only",
  "engines": {
    "HBuilderX": ">=5.7.0",
    "uni-app": "",
    "uni-app-x": "^5.07"
  },
  "uni_modules": {
    "platforms": {
      "app-android": "y",
      "app-ios": "y",
      "web": "n",
      "mp-weixin": "n",
      "cloud": {
        "tcb": "x",
        "aliyun": "x",
        "alipay": "x"
    },
    "client": {
        "uni-app-x": {
            "app": {
                "android": {
                    "extVersion": "0.1.0",
                    "minVersion": "21"
                },
                "harmony": {
                    "extVersion": "0.1.1",
                    "minVersion": "20"
                },
                "ios": {
                    "extVersion": "0.1.0",
                    "minVersion": "12"
                }
            },
            "mp": {
                "weixin": "x"
            },
            "web": {
                "chrome": "x",
                "safari": "x"
            }
        }
    }
    }
  },
  "dcloudext": {
    "type": "uts",
    "sale": {
      "regular": {
        "price": "0.00"
      },
      "sourcecode": {
        "price": "0.00"
      }
    },
    "contact": {
      "qq": ""
    },
    "declaration": {
      "ads": "无",
      "data": "无",
      "permissions": "无"
    },
    "npmurl": "",
    "darkmode": "x",
    "i18n": "x",
    "widescreen": "x"
},
"repository": "https://github.com/openimsdk/openim-sdk-unix"
}
