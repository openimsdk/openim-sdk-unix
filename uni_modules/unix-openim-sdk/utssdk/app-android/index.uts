function optionalString(value ?: string | null) : string { return value != null ? value as string : '' }
function optionalBoolean(value ?: boolean | null) : boolean { return value != null ? value as boolean : false }
function optionalNumber(value ?: number | null) : number { return value != null ? value as number : 0 }
function requireLoggedInForCreate(apiName : string, operationID : string, reject : (reason : any | null) => void) : boolean {
  const loginStatus = parseNativeLoginStatus(NativeOpenIMSDK.getLoginStatus(operationID))
  if (loginStatus != 3) {
    rejectNativeError(reject, -1, apiName + ' requires logged in status')
    return false
  }
  return true
}
function readOfflinePushInfo(options : OpenIMSendMessageOptions) : string { return options.offlinePushInfo != null ? stringifyJSON(options.offlinePushInfo) : '{}' }
function readIsOnlineOnly(options : OpenIMSendMessageOptions) : boolean { return options.isOnlineOnly != null ? options.isOnlineOnly as boolean : false }
function readOperationID(options : OpenIMSendMessageOptions) : string { return options.operationID != null ? options.operationID as string : '' }
function appendPayloadField(payload : string, field : string) : string { return payload.length > 0 ? payload + ',' + field : field }
function stringifyUpdateFriendsPayload(params : OpenIMUpdateFriendsParams) : string {
  let payload = ''
  payload = appendPayloadField(payload, '"friendUserIDs":' + stringifyJSON(params.friendUserIDs))
  if (params.isPinned != null) { payload = appendPayloadField(payload, '"isPinned":' + stringifyJSON(params.isPinned)) }
  if (params.remark != null) { payload = appendPayloadField(payload, '"remark":' + stringifyJSON(params.remark)) }
  if (params.ex != null) { payload = appendPayloadField(payload, '"ex":' + stringifyJSON(params.ex)) }
  return '{' + payload + '}'
}
function stringifySetGroupInfoPayload(params : OpenIMSetGroupInfoParams) : string {
  let payload = ''
  payload = appendPayloadField(payload, '"groupID":' + stringifyJSON(params.groupID))
  if (params.groupName != null) { payload = appendPayloadField(payload, '"groupName":' + stringifyJSON(params.groupName)) }
  if (params.notification != null) { payload = appendPayloadField(payload, '"notification":' + stringifyJSON(params.notification)) }
  if (params.introduction != null) { payload = appendPayloadField(payload, '"introduction":' + stringifyJSON(params.introduction)) }
  if (params.faceURL != null) { payload = appendPayloadField(payload, '"faceURL":' + stringifyJSON(params.faceURL)) }
  if (params.ex != null) { payload = appendPayloadField(payload, '"ex":' + stringifyJSON(params.ex)) }
  if (params.needVerification != null) { payload = appendPayloadField(payload, '"needVerification":' + stringifyJSON(params.needVerification)) }
  if (params.lookMemberInfo != null) { payload = appendPayloadField(payload, '"lookMemberInfo":' + stringifyJSON(params.lookMemberInfo)) }
  if (params.applyMemberFriend != null) { payload = appendPayloadField(payload, '"applyMemberFriend":' + stringifyJSON(params.applyMemberFriend)) }
  if (params.displayIsRead != null) { payload = appendPayloadField(payload, '"displayIsRead":' + stringifyJSON(params.displayIsRead)) }
  return '{' + payload + '}'
}
function stringifySetGroupMemberInfoPayload(params : OpenIMSetGroupMemberInfoParams) : string {
  let payload = ''
  payload = appendPayloadField(payload, '"groupID":' + stringifyJSON(params.groupID))
  payload = appendPayloadField(payload, '"userID":' + stringifyJSON(params.userID))
  if (params.nickname != null) { payload = appendPayloadField(payload, '"nickname":' + stringifyJSON(params.nickname)) }
  if (params.faceURL != null) { payload = appendPayloadField(payload, '"faceURL":' + stringifyJSON(params.faceURL)) }
  if (params.roleLevel != null) { payload = appendPayloadField(payload, '"roleLevel":' + stringifyJSON(params.roleLevel)) }
  if (params.ex != null) { payload = appendPayloadField(payload, '"ex":' + stringifyJSON(params.ex)) }
  return '{' + payload + '}'
}

function resolveStringNative(invoke : (resolve : (data : string) => void, reject : (errCode : number, errMsg : string) => void) => void) : Promise<string> { return new Promise<string>((resolve, reject) => { invoke(resolve, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }
function parseNativeNumberValue(data : string) : number | null { return data.length > 0 ? parseFloat(data) : null }
function parseNativeBooleanValue(data : string) : boolean { return data == 'true' }
function parseNativeBooleanListValue(data : string) : Array<boolean> | null {
  const trimmed = data.trim()
  if (trimmed.length < 2) { return null }
  const result : Array<boolean> = []
  const body = trimmed.substring(1, trimmed.length - 1)
  if (body.length == 0) { return result }
  const items = body.split(',')
  items.forEach((item : string) => { result.push(item.trim() == 'true') })
  return result
}
function parseNativeStringListValue(data : string) : Array<string> | null {
  const trimmed = data.trim()
  if (trimmed.length < 2) { return null }
  const result : Array<string> = []
  const body = trimmed.substring(1, trimmed.length - 1)
  if (body.length == 0) { return result }
  const items = body.split(',')
  items.forEach((item : string) => {
    let value = item.trim()
    if (value.length >= 2 && value.substring(0, 1) == '"' && value.substring(value.length - 1, value.length) == '"') {
      value = value.substring(1, value.length - 1)
    }
    result.push(value)
  })
  return result
}
function resolveNumberNative(invoke : (resolve : (data : string) => void, reject : (errCode : number, errMsg : string) => void) => void) : Promise<number | null> { return new Promise<number | null>((resolve, reject) => { invoke((data : string) => { resolve(parseNativeNumberValue(data)) }, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }
function resolveBooleanNative(invoke : (resolve : (data : string) => void, reject : (errCode : number, errMsg : string) => void) => void) : Promise<boolean> { return new Promise<boolean>((resolve, reject) => { invoke((data : string) => { resolve(parseNativeBooleanValue(data)) }, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }
function resolveBooleanListNative(invoke : (resolve : (data : string) => void, reject : (errCode : number, errMsg : string) => void) => void) : Promise<Array<boolean> | null> { return new Promise<Array<boolean> | null>((resolve, reject) => { invoke((data : string) => { resolve(parseNativeBooleanListValue(data)) }, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }
function resolveStringListNative(invoke : (resolve : (data : string) => void, reject : (errCode : number, errMsg : string) => void) => void) : Promise<Array<string> | null> { return new Promise<Array<string> | null>((resolve, reject) => { invoke((data : string) => { resolve(parseNativeStringListValue(data)) }, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }
