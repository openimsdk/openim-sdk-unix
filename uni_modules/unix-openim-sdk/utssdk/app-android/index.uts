export const sendMessage = function (options : OpenIMSendMessageOptions) : Promise<OpenIMMessageItem> { return new Promise<OpenIMMessageItem>((resolve, reject) => { NativeOpenIMSDK.sendMessage(readOperationID(options), stringifyOpenIMMessage(options.message), options.recvID, options.groupID, readOfflinePushInfo(options), readIsOnlineOnly(options), (data : string) => { const message = parseNativeMessage(data); if (message != null) { resolve(message) } else { rejectNativeError(reject, -1, 'sendMessage returned invalid message data') } }, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }
export const sendMessageNotOss = function (options : OpenIMSendMessageOptions) : Promise<OpenIMMessageItem> { return new Promise<OpenIMMessageItem>((resolve, reject) => { NativeOpenIMSDK.sendMessageNotOss(readOperationID(options), stringifyOpenIMMessage(options.message), options.recvID, options.groupID, readOfflinePushInfo(options), readIsOnlineOnly(options), (data : string) => { const message = parseNativeMessage(data); if (message != null) { resolve(message) } else { rejectNativeError(reject, -1, 'sendMessageNotOss returned invalid message data') } }, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }

export const uploadFile = function (params : OpenIMUploadFileParams, operationID ?: string | null) : Promise<OpenIMUploadFileResult | null> {
  return new Promise<OpenIMUploadFileResult | null>((resolve, reject) => {
    NativeOpenIMSDK.uploadFile(normalizeOperationID(operationID), stringifyJSON(params), (data : string) => {
      resolve(parseNativeUploadFileResult(data))
    }, (errCode : number, errMsg : string) => {
      rejectNativeError(reject, errCode, errMsg)
    })
  })
}
