export const initSDK = function (config : OpenIMInitConfig, operationID ?: string | null) : Promise<boolean> { return new Promise<boolean>((resolve, reject) => { ensureNativeEventsBound(); resolve(NativeOpenIMSDK.initSDK(normalizeOperationID(operationID), normalizeInitConfig(config)) == 'true') }) }
export const login = function (userID : string, token : string, operationID ?: string | null) : Promise<string> { return new Promise<string>((resolve, reject) => { NativeOpenIMSDK.login(normalizeOperationID(operationID), userID, token, resolve, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }
export const logout = function (operationID ?: string | null) : Promise<string> { return new Promise<string>((resolve, reject) => { NativeOpenIMSDK.logout(normalizeOperationID(operationID), resolve, (errCode : number, errMsg : string) => { rejectNativeError(reject, errCode, errMsg) }) }) }
export const getLoginStatus = function (operationID ?: string | null) : Promise<OpenIMLoginStatus> { return new Promise<OpenIMLoginStatus>((resolve, reject) => { resolve(parseNativeLoginStatus(NativeOpenIMSDK.getLoginStatus(normalizeOperationID(operationID)))) }) }
export const getLoginUserID = function () : Promise<string> { return new Promise<string>((resolve, reject) => { resolve(NativeOpenIMSDK.getLoginUserID()) }) }
export const getSdkVersion = function () : string { return NativeOpenIMSDK.getSdkVersion() }
export const getOpenIMDataPath = function () : string { return getOpenIMDataPathNative() }
export const unInitSDK = function (operationID ?: string | null) { NativeOpenIMSDK.unInitSDK(normalizeOperationID(operationID)) }

