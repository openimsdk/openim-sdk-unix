export type OpenIMConversationListEventHandler = (result : OpenIMConversationListResult | null) => void
export type OpenIMConversationInputStatusEventHandler = (status : OpenIMConversationInputStatusItem | null) => void
export type OpenIMFriendEventHandler = (friend : OpenIMFriendUserItem | null) => void
export type OpenIMBlackUserEventHandler = (blackUser : OpenIMBlackUserItem | null) => void
export type OpenIMFriendApplicationEventHandler = (application : OpenIMFriendApplicationItem | null) => void
export type OpenIMGroupEventHandler = (group : OpenIMGroupItem | null) => void
export type OpenIMGroupMemberEventHandler = (member : OpenIMGroupMemberItem | null) => void
export type OpenIMGroupApplicationEventHandler = (application : OpenIMGroupApplicationItem | null) => void
export type OpenIMUserEventHandler = (user : OpenIMUserInfo | null) => void
export type OpenIMUserStatusListEventHandler = (result : OpenIMUserStatusListResult | null) => void
export type OpenIMSendMessageProgressEventHandler = (progress : OpenIMSendMessageProgressEvent | null) => void
export type OpenIMUploadFileProgressEventHandler = (progress : OpenIMUploadFileProgressEvent | null) => void
export type OpenIMUploadLogsProgressEventHandler = (progress : OpenIMUploadLogsProgressEvent | null) => void

export type OpenIMSDKEventSubscription = {
  id : string
  eventName : OpenIMSDKEventName
}

export type OpenIMSDKUnsubscribe = () => void

export type OpenIMSDKEventHandlerSubscription = {
  id : string
  eventName : OpenIMSDKEventName
  handler : OpenIMSDKRawEventHandler
}

export type OffSDKEventName = (eventName : OpenIMSDKEventName) => void
export type InitSDK = (config : OpenIMInitConfig, operationID ?: string | null) => Promise<boolean>
export type Login = (userID : string, token : string, operationID ?: string | null) => Promise<string>
export type Logout = (operationID ?: string | null) => Promise<string>
export type GetLoginStatus = (operationID ?: string | null) => Promise<OpenIMLoginStatus>
export type GetLoginUserID = () => Promise<string>
export type CreateTextMessage = (text : string, operationID ?: string | null) => Promise<OpenIMMessageItem | null>
export type SendMessage = (options : OpenIMSendMessageOptions) => Promise<OpenIMMessageItem>
export type UploadFile = (params : OpenIMUploadFileParams, operationID ?: string | null) => Promise<OpenIMUploadFileResult | null>

export type OpenIMSDKInstance = {
  initSDK : InitSDK
  login : Login
  logout : Logout
  getLoginStatus : GetLoginStatus
  getLoginUserID : GetLoginUserID
  createTextMessage : CreateTextMessage
  sendMessage : SendMessage
  uploadFile : UploadFile
}

