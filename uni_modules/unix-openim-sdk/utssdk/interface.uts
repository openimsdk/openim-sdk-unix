export type OpenIMSDKEvent = {
  eventName : OpenIMSDKEventName
  payload : string
  errCode : number
  errMsg : string
}

export type OpenIMSDKRawEventHandler = (event : OpenIMSDKEvent) => void
export type OpenIMVoidEventHandler = () => void
export type OpenIMErrorEventHandler = (errCode : number, errMsg : string) => void
export type OpenIMStringEventHandler = (payload : string) => void
export type OpenIMBooleanEventHandler = (value : boolean) => void
export type OpenIMNumberEventHandler = (value : number) => void
export type OpenIMMessageEventHandler = (message : OpenIMMessageItem | null) => void
export type OpenIMMessageListEventHandler = (result : OpenIMMessageListResult | null) => void
export type OpenIMMessageRevokedEventHandler = (revoked : OpenIMMessageRevokedItem | null) => void
