function stringifyAtUsersInfoList(value ?: Array<OpenIMAtUsersInfoItem> | null) : string {
  if (value == null) { return '[]' }
  const list = value as Array<OpenIMAtUsersInfoItem>
  let text = ''
  list.forEach((item : OpenIMAtUsersInfoItem) => {
    let itemText = ''
    itemText = appendOptionalJSONStringText(itemText, 'atUserID', item.atUserID)
    itemText = appendOptionalJSONStringText(itemText, 'groupNickname', item.groupNickname)
    text = appendJSONText(text, '{' + itemText + '}')
  })
  return '[' + text + ']'
}

