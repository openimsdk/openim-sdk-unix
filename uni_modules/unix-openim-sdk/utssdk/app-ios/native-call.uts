type NativeOpenIMInitConfig = {
  platformID : number
  apiAddr : string
  wsAddr : string
  dataDir : string
  logFilePath : string
  logLevel : number
  isLogStandardOutput : boolean
  systemType : string
}

function normalizeWritablePath(path : string | null) : string {
  if (path == null || path.length == 0 || path.indexOf('unifile:') >= 0) {
    return UTSiOS.getDataPath()
  }
  return path
}

export function getOpenIMDataPathNative() : string {
  return UTSiOS.getDataPath()
}

export function normalizeInitConfig(config : OpenIMInitConfig) : string {
  const nativeConfig : NativeOpenIMInitConfig = {
    platformID: config.platformID,
    apiAddr: config.apiAddr,
    wsAddr: config.wsAddr,
    dataDir: normalizeWritablePath(config.dataDir != null ? config.dataDir as string : null),
    logFilePath: normalizeWritablePath(config.logFilePath != null ? config.logFilePath as string : null),
    logLevel: config.logLevel,
    isLogStandardOutput: config.isLogStandardOutput,
    systemType: config.systemType
  }
  const configText = JSON.stringify(nativeConfig as any)
  if (configText != null) {
    return configText as string
  }
  return '{}'
}

export function parseNativeMessage(data : string) : OpenIMMessageItem | null {
  return parseNativeMessageCommon(data, getNativeParserHelpers())
}

export function readStringParam(value : any | null, key : string) : string {
  const raw = readNativeValue(value, key)
  if (raw != null) {
    if (typeof raw == 'string') {
      return raw as string
    }
  }
  return ''
}

export function readNumberParam(value : any | null, key : string) : number {
  const raw = readNativeValue(value, key)
  if (raw != null) {
    if (typeof raw == 'number') {
      return raw as number
    }
  }
  return 0
}

export function readBooleanParam(value : any | null, key : string) : boolean {
  const raw = readNativeValue(value, key)
  if (raw != null) {
    if (typeof raw == 'boolean') {
      return raw as boolean
    }
  }
  return false
}

function parseNativeAny(data : string) : any | null {
  const trimmed = data.trim()
  if (trimmed.length == 0) {
    return null
  }
  try {
    return JSON.parse(trimmed)
  } catch (error) {
    return data
  }
}

function parseNativeJSONObjectListData(data : string) : Array<UTSJSONObject> | null {
  return JSON.parseArray<UTSJSONObject>(data)
}

export function stringifyOpenIMPicture(value : OpenIMPicture | null) : string {
  if (value == null) { return '{}' }
  let text = ''
  text = appendOptionalJSONStringText(text, 'uuid', value.uuid)
  text = appendOptionalJSONStringText(text, 'type', value.type)
  text = appendOptionalJSONNumberText(text, 'size', value.size)
  text = appendOptionalJSONNumberText(text, 'width', value.width)
  text = appendOptionalJSONNumberText(text, 'height', value.height)
  text = appendOptionalJSONStringText(text, 'url', value.url)
  return '{' + text + '}'
}

function stringifyOpenIMPictureElem(value : OpenIMPictureElem) : string {
  let text = ''
  text = appendOptionalJSONStringText(text, 'sourcePath', value.sourcePath)
  if (value.sourcePicture != null) { text = appendJSONText(text, buildJSONField('sourcePicture', stringifyOpenIMPicture(value.sourcePicture))) }
  if (value.bigPicture != null) { text = appendJSONText(text, buildJSONField('bigPicture', stringifyOpenIMPicture(value.bigPicture))) }
  if (value.snapshotPicture != null) { text = appendJSONText(text, buildJSONField('snapshotPicture', stringifyOpenIMPicture(value.snapshotPicture))) }
  return '{' + text + '}'
}

function stringifyOpenIMMessageContentElem(content ?: string | null) : string | null {
  if (content != null && (content as string).length > 0) { return content as string }
  return null
}

function stringifyOpenIMPictureElemForMessage(message : OpenIMMessageItem) : string {
  const content = stringifyOpenIMMessageContentElem(message.content)
  if (content != null) { return content }
  if (message.pictureElem != null) { return stringifyOpenIMPictureElem(message.pictureElem as OpenIMPictureElem) }
  return '{}'
}

