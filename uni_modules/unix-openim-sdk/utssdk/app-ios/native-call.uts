  let text = ''
  text = appendOptionalJSONNumberText(text, 'hasReadCount', value.hasReadCount)
  text = appendOptionalJSONNumberText(text, 'unreadCount', value.unreadCount)
  if (value.hasReadUserIDList != null) { text = appendJSONText(text, buildJSONField('hasReadUserIDList', stringifyStringList(value.hasReadUserIDList))) }
  text = appendOptionalJSONNumberText(text, 'groupMemberCount', value.groupMemberCount)
  return '{' + text + '}'
}

function stringifyOpenIMUploadProgress(value : OpenIMUploadProgress) : string {
  let text = ''
  text = appendOptionalJSONNumberText(text, 'total', value.total)
  text = appendOptionalJSONNumberText(text, 'save', value.save)
  text = appendOptionalJSONNumberText(text, 'current', value.current)
  text = appendOptionalJSONStringText(text, 'uploadID', value.uploadID)
  return '{' + text + '}'
}

function stringifyOpenIMAttachedInfoElem(value : OpenIMAttachedInfoElem) : string {
  let text = ''
  if (value.groupHasReadInfo != null) { text = appendJSONText(text, buildJSONField('groupHasReadInfo', stringifyOpenIMAttachedGroupHasReadInfo(value.groupHasReadInfo as OpenIMAttachedGroupHasReadInfo))) }
  text = appendOptionalJSONBooleanText(text, 'isPrivateChat', value.isPrivateChat)
  text = appendOptionalJSONBooleanText(text, 'isEncryption', value.isEncryption)
  text = appendOptionalJSONBooleanText(text, 'inEncryptStatus', value.inEncryptStatus)
  text = appendOptionalJSONNumberText(text, 'burnDuration', value.burnDuration)
  text = appendOptionalJSONNumberText(text, 'hasReadTime', value.hasReadTime)
  if (value.messageEntityList != null) { text = appendJSONText(text, buildJSONField('messageEntityList', stringifyOpenIMMessageEntityList(value.messageEntityList))) }
  if (value.uploadProgress != null) { text = appendJSONText(text, buildJSONField('uploadProgress', stringifyOpenIMUploadProgress(value.uploadProgress as OpenIMUploadProgress))) }
  return '{' + text + '}'
}

function appendOpenIMMessageRefFieldsText(text : string, message : OpenIMMessageItemRef) : string {
  let json = text
  json = appendOptionalJSONStringText(json, 'clientMsgID', message.clientMsgID)
  json = appendOptionalJSONStringText(json, 'serverMsgID', message.serverMsgID)
  json = appendJSONText(json, buildJSONField('createTime', stringifyJSONNumber(message.createTime)))
  json = appendJSONText(json, buildJSONField('sendTime', stringifyJSONNumber(message.sendTime)))
  json = appendJSONText(json, buildJSONField('sessionType', stringifyJSONNumber(message.sessionType as number)))
  json = appendOptionalJSONStringText(json, 'sendID', message.sendID)
  json = appendOptionalJSONStringText(json, 'recvID', message.recvID)
  json = appendJSONText(json, buildJSONField('msgFrom', stringifyJSONNumber(message.msgFrom)))
  json = appendJSONText(json, buildJSONField('contentType', stringifyJSONNumber(message.contentType as number)))
  json = appendJSONText(json, buildJSONField('senderPlatformID', stringifyJSONNumber(message.senderPlatformID as number)))
  json = appendOptionalJSONStringText(json, 'senderNickname', message.senderNickname)
  json = appendOptionalJSONStringText(json, 'senderFaceUrl', message.senderFaceUrl)
  json = appendOptionalJSONStringText(json, 'groupID', message.groupID)
  json = appendOptionalJSONStringText(json, 'content', message.content)
  json = appendJSONText(json, buildJSONField('seq', stringifyJSONNumber(message.seq)))
  json = appendJSONText(json, buildJSONField('isRead', stringifyJSONBoolean(message.isRead)))
  json = appendJSONText(json, buildJSONField('status', stringifyJSONNumber(message.status as number)))
  json = appendOptionalJSONStringText(json, 'attachedInfo', message.attachedInfo)
  json = appendOptionalJSONStringText(json, 'ex', message.ex)
  json = appendOptionalJSONStringText(json, 'localEx', message.localEx)
  if (message.textElem != null) { json = appendJSONText(json, buildJSONField('textElem', stringifyOpenIMTextElem(message.textElem as OpenIMTextElem))) }
  return json
}

function stringifyOpenIMMessageRef(message : OpenIMMessageItemRef) : string {
  return '{' + appendOpenIMMessageRefFieldsText('', message) + '}'
}

function stringifyOpenIMMessageRefList(value : Array<OpenIMMessageItemRef>) : string {
  let text = ''
  value.forEach((message : OpenIMMessageItemRef) => { text = appendJSONText(text, stringifyOpenIMMessageRef(message)) })
  return '[' + text + ']'
}

function stringifyOpenIMQuoteElem(value : OpenIMQuoteElem) : string {
  let text = ''
  text = appendOptionalJSONStringText(text, 'text', value.text)
  if (value.quoteMessage != null) { text = appendJSONText(text, buildJSONField('quoteMessage', stringifyOpenIMMessageRef(value.quoteMessage as OpenIMMessageItemRef))) }
  if (value.messageEntityList != null) { text = appendJSONText(text, buildJSONField('messageEntityList', stringifyOpenIMMessageEntityList(value.messageEntityList))) }
  return '{' + text + '}'
}

function stringifyOpenIMQuoteElemForMessage(message : OpenIMMessageItem) : string {
  const content = stringifyOpenIMMessageContentElem(message.content)
  if (content != null) { return content }
  if (message.quoteElem != null) { return stringifyOpenIMQuoteElem(message.quoteElem as OpenIMQuoteElem) }
  return '{}'
}

function stringifyOpenIMAtTextElem(value : OpenIMAtTextElem) : string {
  let text = ''
  text = appendOptionalJSONStringText(text, 'text', value.text)
  if (value.atUserList != null) { text = appendJSONText(text, buildJSONField('atUserList', stringifyStringList(value.atUserList))) }
  if (value.atUsersInfo != null) { text = appendJSONText(text, buildJSONField('atUsersInfo', stringifyAtUsersInfoList(value.atUsersInfo))) }
  if (value.quoteMessage != null) { text = appendJSONText(text, buildJSONField('quoteMessage', stringifyOpenIMMessageRef(value.quoteMessage as OpenIMMessageItemRef))) }
  text = appendOptionalJSONBooleanText(text, 'isAtSelf', value.isAtSelf)
  return '{' + text + '}'
}

function stringifyOpenIMAtTextElemForMessage(message : OpenIMMessageItem) : string {
  const content = stringifyOpenIMMessageContentElem(message.content)
  if (content != null) { return content }
  if (message.atTextElem != null) { return stringifyOpenIMAtTextElem(message.atTextElem as OpenIMAtTextElem) }
  return '{}'
}

function stringifyOpenIMMergeElem(value : OpenIMMergeElem) : string {
  let text = ''
  text = appendOptionalJSONStringText(text, 'title', value.title)
  if (value.abstractList != null) { text = appendJSONText(text, buildJSONField('abstractList', stringifyStringList(value.abstractList))) }
  if (value.multiMessage != null) { text = appendJSONText(text, buildJSONField('multiMessage', stringifyOpenIMMessageRefList(value.multiMessage as Array<OpenIMMessageItemRef>))) }
  if (value.messageEntityList != null) { text = appendJSONText(text, buildJSONField('messageEntityList', stringifyOpenIMMessageEntityList(value.messageEntityList))) }
  return '{' + text + '}'
}

function stringifyOpenIMMergeElemForMessage(message : OpenIMMessageItem) : string {
  if (message.content != null && (message.content as string).length > 0) { return message.content as string }
  if (message.mergeElem != null) {
    const elem = message.mergeElem as OpenIMMergeElem
    let text = ''
    text = appendOptionalJSONStringText(text, 'title', elem.title)
    if (elem.abstractList != null) { text = appendJSONText(text, buildJSONField('abstractList', stringifyStringList(elem.abstractList))) }
    return '{' + text + '}'
  }
  return '{}'
}

function stringifyOpenIMMessageItem(message : OpenIMMessageItem) : string {
  let json = ''
  json = appendOptionalJSONStringText(json, 'clientMsgID', message.clientMsgID)
  json = appendOptionalJSONStringText(json, 'serverMsgID', message.serverMsgID)
  json = appendJSONText(json, buildJSONField('createTime', stringifyJSONNumber(message.createTime)))
  json = appendJSONText(json, buildJSONField('sendTime', stringifyJSONNumber(message.sendTime)))
  json = appendJSONText(json, buildJSONField('sessionType', stringifyJSONNumber(message.sessionType as number)))
  json = appendOptionalJSONStringText(json, 'sendID', message.sendID)
  json = appendOptionalJSONStringText(json, 'recvID', message.recvID)
  json = appendJSONText(json, buildJSONField('msgFrom', stringifyJSONNumber(message.msgFrom)))
  json = appendJSONText(json, buildJSONField('contentType', stringifyJSONNumber(message.contentType as number)))
  json = appendJSONText(json, buildJSONField('senderPlatformID', stringifyJSONNumber(message.senderPlatformID as number)))
  json = appendOptionalJSONStringText(json, 'senderNickname', message.senderNickname)
  json = appendOptionalJSONStringText(json, 'senderFaceUrl', message.senderFaceUrl)
  json = appendOptionalJSONStringText(json, 'groupID', message.groupID)
  json = appendOptionalJSONStringText(json, 'content', message.content)
  json = appendJSONText(json, buildJSONField('seq', stringifyJSONNumber(message.seq)))
  json = appendJSONText(json, buildJSONField('isRead', stringifyJSONBoolean(message.isRead)))
  json = appendJSONText(json, buildJSONField('status', stringifyJSONNumber(message.status as number)))
  json = appendOptionalJSONStringText(json, 'attachedInfo', message.attachedInfo)
  json = appendOptionalJSONStringText(json, 'ex', message.ex)
  json = appendOptionalJSONStringText(json, 'localEx', message.localEx)
  if (message.textElem != null) { json = appendJSONText(json, buildJSONField('textElem', stringifyOpenIMTextElemForMessage(message))) }
  if (message.cardElem != null) { json = appendJSONText(json, buildJSONField('cardElem', stringifyOpenIMCardElemForMessage(message))) }
  if (message.pictureElem != null) { json = appendJSONText(json, buildJSONField('pictureElem', stringifyOpenIMPictureElemForMessage(message))) }
  if (message.soundElem != null) { json = appendJSONText(json, buildJSONField('soundElem', stringifyOpenIMSoundElemForMessage(message))) }
  if (message.videoElem != null) { json = appendJSONText(json, buildJSONField('videoElem', stringifyOpenIMVideoElemForMessage(message))) }
  if (message.fileElem != null) { json = appendJSONText(json, buildJSONField('fileElem', stringifyOpenIMFileElemForMessage(message))) }
  if (message.mergeElem != null) { json = appendJSONText(json, buildJSONField('mergeElem', stringifyOpenIMMergeElemForMessage(message))) }
  if (message.atTextElem != null) { json = appendJSONText(json, buildJSONField('atTextElem', stringifyOpenIMAtTextElemForMessage(message))) }
  if (message.quoteElem != null) { json = appendJSONText(json, buildJSONField('quoteElem', stringifyOpenIMQuoteElemForMessage(message))) }
  if (message.faceElem != null) { json = appendJSONText(json, buildJSONField('faceElem', stringifyOpenIMFaceElemForMessage(message))) }
  if (message.locationElem != null) { json = appendJSONText(json, buildJSONField('locationElem', stringifyOpenIMLocationElemForMessage(message))) }
  if (message.customElem != null) { json = appendJSONText(json, buildJSONField('customElem', stringifyOpenIMCustomElemForMessage(message))) }
  if (message.advancedTextElem != null) { json = appendJSONText(json, buildJSONField('advancedTextElem', stringifyOpenIMAdvancedTextElemForMessage(message))) }
  if (message.attachedInfoElem != null) { json = appendJSONText(json, buildJSONField('attachedInfoElem', stringifyOpenIMAttachedInfoElem(message.attachedInfoElem as OpenIMAttachedInfoElem))) }
  return '{' + json + '}'
}

export function stringifyOpenIMMessage(message : OpenIMMessageItem | null) : string {
  if (message == null) { return '{}' }
  return stringifyOpenIMMessageItem(message as OpenIMMessageItem)
}

export function stringifyOpenIMMessageList(messages : Array<OpenIMMessageItem>) : string {
  const items : Array<string> = []
  messages.forEach((message : OpenIMMessageItem) => { items.push(stringifyOpenIMMessageItem(message)) })
  return '[' + items.join(',') + ']'
}

export function stringifyOpenIMMessagePayload(value : any | null) : string {
  if (value == null) { return '{}' }
  if (value instanceof Array) { return stringifyOpenIMMessageList(value as Array<OpenIMMessageItem>) }
  return stringifyOpenIMMessage(value as OpenIMMessageItem)
}

function isRequiredNumberField(value : UTSJSONObject, key : string) : boolean {
  const raw = readNativeValue(value, key)
  return raw != null && typeof raw == 'number'
}

function isRequiredStringField(value : UTSJSONObject, key : string) : boolean {
  const raw = readNativeValue(value, key)
  return raw != null && typeof raw == 'string'
}

function isOptionalNumberField(value : UTSJSONObject, key : string) : boolean {
  const raw = readNativeValue(value, key)
  return raw == null || typeof raw == 'number'
}

function isCommonRequiredField(value : UTSJSONObject, key : string) : boolean {
  if (key == 'conversationType' || key == 'recvMsgOpt' || key == 'unreadCount' || key == 'latestMsgSendTime' || key == 'draftTextTime' || key == 'burnDuration' || key == 'minSeq' || key == 'maxSeq' || key == 'msgDestructTime' || key == 'groupAtType' || key == 'updateUnreadCountTime' || key == 'status' || key == 'type' || key == 'createTime' || key == 'sendTime' || key == 'sessionType' || key == 'msgFrom' || key == 'contentType' || key == 'senderPlatformID' || key == 'seq' || key == 'revokeTime' || key == 'readTime' || key == 'addSource' || key == 'memberCount' || key == 'groupType' || key == 'needVerification' || key == 'lookMemberInfo' || key == 'applyMemberFriend' || key == 'notificationUpdateTime' || key == 'roleLevel' || key == 'joinTime' || key == 'joinSource' || key == 'muteEndTime' || key == 'handleResult' || key == 'handleTime' || key == 'reqTime' || key == 'handledTime') {
    return isRequiredNumberField(value, key)
  }
  return isRequiredStringField(value, key)
}

function parseNativeConversationItemData(data : string) : OpenIMConversationItem | null { return JSON.parseObject<OpenIMConversationItem>(data) }

function parseNativeConversationListData(data : string) : Array<OpenIMConversationItem> | null { return JSON.parseArray<OpenIMConversationItem>(data) }

function parseNativeUserInfoData(data : string) : OpenIMUserInfo | null { return JSON.parseObject<OpenIMUserInfo>(data) }

function parseNativeUserInfoListData(data : string) : Array<OpenIMUserInfo> | null { return JSON.parseArray<OpenIMUserInfo>(data) }

function parseNativeFriendUserListData(data : string) : Array<OpenIMFriendUserItem> | null { return JSON.parseArray<OpenIMFriendUserItem>(data) }

function parseNativeBlackUserListData(data : string) : Array<OpenIMBlackUserItem> | null { return JSON.parseArray<OpenIMBlackUserItem>(data) }

function parseNativeGroupData(data : string) : OpenIMGroupItem | null { return JSON.parseObject<OpenIMGroupItem>(data) }

function parseNativeGroupListData(data : string) : Array<OpenIMGroupItem> | null { return JSON.parseArray<OpenIMGroupItem>(data) }

function parseNativeGroupMemberListData(data : string) : Array<OpenIMGroupMemberItem> | null { return JSON.parseArray<OpenIMGroupMemberItem>(data) }

function parseNativeFriendApplicationListData(data : string) : Array<OpenIMFriendApplicationItem> | null { return JSON.parseArray<OpenIMFriendApplicationItem>(data) }

function parseNativeGroupApplicationListData(data : string) : Array<OpenIMGroupApplicationItem> | null { return JSON.parseArray<OpenIMGroupApplicationItem>(data) }

function parseNativeMessageData(data : string) : OpenIMMessageItem | null { return JSON.parseObject<OpenIMMessageItem>(data) }

function parseNativeMessageListData(data : string) : Array<OpenIMMessageItem> | null { return JSON.parseArray<OpenIMMessageItem>(data) }

function parseNativeAdvancedHistoryMessageListData(data : string) : OpenIMAdvancedHistoryMessageListResult | null { return JSON.parseObject<OpenIMAdvancedHistoryMessageListResult>(data) }

function parseNativeStringListData(data : string) : Array<string> | null { return JSON.parseArray<string>(data) }

const nativeParserHelpers : NativeParserHelpers = {
  parseNativeAny: (data : string) : any | null => { return parseNativeAny(data) },
  parseNativeJSONObjectListData: (data : string) : Array<UTSJSONObject> | null => { return parseNativeJSONObjectListData(data) },
  parseNativeConversationItemData: (data : string) : OpenIMConversationItem | null => { return parseNativeConversationItemData(data) },
  parseNativeConversationListData: (data : string) : Array<OpenIMConversationItem> | null => { return parseNativeConversationListData(data) },
  parseNativeUserInfoData: (data : string) : OpenIMUserInfo | null => { return parseNativeUserInfoData(data) },
  parseNativeUserInfoListData: (data : string) : Array<OpenIMUserInfo> | null => { return parseNativeUserInfoListData(data) },
  parseNativeFriendUserListData: (data : string) : Array<OpenIMFriendUserItem> | null => { return parseNativeFriendUserListData(data) },
  parseNativeBlackUserListData: (data : string) : Array<OpenIMBlackUserItem> | null => { return parseNativeBlackUserListData(data) },
  parseNativeGroupData: (data : string) : OpenIMGroupItem | null => { return parseNativeGroupData(data) },
  parseNativeGroupListData: (data : string) : Array<OpenIMGroupItem> | null => { return parseNativeGroupListData(data) },
  parseNativeGroupMemberListData: (data : string) : Array<OpenIMGroupMemberItem> | null => { return parseNativeGroupMemberListData(data) },
  parseNativeFriendApplicationListData: (data : string) : Array<OpenIMFriendApplicationItem> | null => { return parseNativeFriendApplicationListData(data) },
  parseNativeGroupApplicationListData: (data : string) : Array<OpenIMGroupApplicationItem> | null => { return parseNativeGroupApplicationListData(data) },
  parseNativeMessageData: (data : string) : OpenIMMessageItem | null => { return parseNativeMessageData(data) },
  parseNativeMessageListData: (data : string) : Array<OpenIMMessageItem> | null => { return parseNativeMessageListData(data) },
  parseNativeAdvancedHistoryMessageListData: (data : string) : OpenIMAdvancedHistoryMessageListResult | null => { return parseNativeAdvancedHistoryMessageListData(data) },
  parseNativeStringListData: (data : string) : Array<string> | null => { return parseNativeStringListData(data) },
  readStringParam: (value : any | null, key : string) : string => { return readStringParam(value, key) },
  readNumberParam: (value : any | null, key : string) : number => { return readNumberParam(value, key) },
  readBooleanParam: (value : any | null, key : string) : boolean => { return readBooleanParam(value, key) },
  isRequiredField: (value : UTSJSONObject, key : string) : boolean => { return isCommonRequiredField(value, key) },
  isOptionalNumberField: (value : UTSJSONObject, key : string) : boolean => { return isOptionalNumberField(value, key) }
}

function getNativeParserHelpers() : NativeParserHelpers { return nativeParserHelpers }

