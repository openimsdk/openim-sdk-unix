function stringifyOpenIMAdvancedTextElemForMessage(message : OpenIMMessageItem) : string {
  const content = stringifyOpenIMMessageContentElem(message.content)
  if (content != null) { return content }
  if (message.advancedTextElem != null) {
    const elem = message.advancedTextElem as OpenIMAdvancedTextElem
    let text = ''
    text = appendOptionalJSONStringText(text, 'text', elem.text)
    if (elem.messageEntityList != null) { text = appendJSONText(text, buildJSONField('messageEntityList', stringifyOpenIMMessageEntityList(elem.messageEntityList))) }
    return '{' + text + '}'
  }
  return '{}'
}

