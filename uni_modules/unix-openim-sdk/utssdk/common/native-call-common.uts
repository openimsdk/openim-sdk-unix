function parseNativeGroupItem(item : UTSJSONObject, helpers : NativeParserHelpers) : OpenIMGroupItem {
  return { groupID: helpers.readStringParam(item, 'groupID'), groupName: helpers.readStringParam(item, 'groupName'), notification: helpers.readStringParam(item, 'notification'), introduction: helpers.readStringParam(item, 'introduction'), faceURL: helpers.readStringParam(item, 'faceURL'), ownerUserID: helpers.readStringParam(item, 'ownerUserID'), createTime: helpers.readNumberParam(item, 'createTime'), memberCount: helpers.readNumberParam(item, 'memberCount'), status: helpers.readNumberParam(item, 'status'), creatorUserID: helpers.readStringParam(item, 'creatorUserID'), groupType: helpers.readNumberParam(item, 'groupType'), needVerification: helpers.readNumberParam(item, 'needVerification'), lookMemberInfo: helpers.readNumberParam(item, 'lookMemberInfo'), applyMemberFriend: helpers.readNumberParam(item, 'applyMemberFriend'), notificationUpdateTime: helpers.readNumberParam(item, 'notificationUpdateTime'), notificationUserID: helpers.readStringParam(item, 'notificationUserID'), ex: helpers.readStringParam(item, 'ex'), attachedInfo: helpers.readStringParam(item, 'attachedInfo') }
}

