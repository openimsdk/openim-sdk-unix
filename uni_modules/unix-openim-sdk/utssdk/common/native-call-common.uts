function parseNativeGroupMemberItem(item : UTSJSONObject, helpers : NativeParserHelpers) : OpenIMGroupMemberItem {
  return { groupID: helpers.readStringParam(item, 'groupID'), userID: helpers.readStringParam(item, 'userID'), nickname: helpers.readStringParam(item, 'nickname'), faceURL: helpers.readStringParam(item, 'faceURL'), roleLevel: helpers.readNumberParam(item, 'roleLevel'), joinTime: helpers.readNumberParam(item, 'joinTime'), joinSource: helpers.readNumberParam(item, 'joinSource'), operatorUserID: helpers.readStringParam(item, 'operatorUserID'), ex: helpers.readStringParam(item, 'ex'), muteEndTime: helpers.readNumberParam(item, 'muteEndTime'), inviterUserID: helpers.readStringParam(item, 'inviterUserID'), attachedInfo: helpers.readStringParam(item, 'attachedInfo') }
}

function isValidParsedGroupMemberList(members : Array<OpenIMGroupMemberItem>, helpers : NativeParserHelpers) : boolean {
  let index = 0
  while (index < members.length) {
    const raw = parseObjectFromValue(members[index], helpers)
    if (raw == null || helpers.isRequiredField(raw, 'roleLevel') == false || helpers.isRequiredField(raw, 'joinTime') == false || helpers.isRequiredField(raw, 'joinSource') == false || helpers.isRequiredField(raw, 'muteEndTime') == false) { return false }
    index = index + 1
  }
  return true
}

export function parseNativeGroupMemberListResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMGroupMemberListResult | null {
  const typedList = helpers.parseNativeGroupMemberListData(data)
