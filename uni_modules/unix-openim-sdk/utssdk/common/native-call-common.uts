export function parseNativeMessageEventListFallbackCommon(data : string, helpers : NativeParserHelpers) : OpenIMMessageListResult | null {
  const rawList = helpers.parseNativeJSONObjectListData(data)
  if (rawList == null) { return null }
  const messages : Array<OpenIMMessageItem> = []
  let valid = true
  rawList.forEach((item : UTSJSONObject) => { if (isValidParsedMessageObject(item, helpers)) { messages.push(parseNativeMessageItem(item, helpers)) } else { valid = false } })
  if (valid == false) { return null }
  return { messages: messages }
}

function parseNativeFindMessageResultItem(item : UTSJSONObject, helpers : NativeParserHelpers) : OpenIMFindMessageResultItem {
  return { conversationID: helpers.readStringParam(item, 'conversationID'), conversationType: helpers.readNumberParam(item, 'conversationType') as OpenIMSessionType, showName: helpers.readStringParam(item, 'showName'), faceURL: helpers.readStringParam(item, 'faceURL'), latestMsgSendTime: helpers.readNumberParam(item, 'latestMsgSendTime'), messageCount: helpers.readNumberParam(item, 'messageCount'), messageList: parseNativeMessageListFromValue(readNativeValue(item, 'messageList'), helpers) }
}

export function parseNativeFindMessageResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMFindMessageResult | null {
  const raw = helpers.parseNativeAny(data)
  if (!(raw instanceof UTSJSONObject)) { return null }
  const items : Array<OpenIMFindMessageResultItem> = []
  const rawList = parseNativeJSONObjectList(readNativeValue(raw, 'findResultItems'), helpers)
  rawList.forEach((item : UTSJSONObject) => { items.push(parseNativeFindMessageResultItem(item, helpers)) })
  return { totalCount: helpers.readNumberParam(raw, 'totalCount'), findResultItems: items }
}

export function parseNativeMessageListResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMFindMessageResult | null {
  return parseNativeFindMessageResultCommon(data, helpers)
}

export function parseNativeSearchMessageResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMSearchMessageResult | null {
  const raw = helpers.parseNativeAny(data)
  if (!(raw instanceof UTSJSONObject)) { return null }
  const items : Array<OpenIMSearchMessageResultItem> = []
  const rawList = parseNativeJSONObjectList(readNativeValue(raw, 'searchResultItems'), helpers)
  rawList.forEach((item : UTSJSONObject) => { items.push(parseNativeFindMessageResultItem(item, helpers)) })
  return { totalCount: helpers.readNumberParam(raw, 'totalCount'), searchResultItems: items }
}

export function parseNativeMessageRevokedCommon(data : string, helpers : NativeParserHelpers) : OpenIMMessageRevokedItem | null {
  const raw = helpers.parseNativeAny(data)
  if (raw instanceof UTSJSONObject && helpers.isRequiredField(raw, 'clientMsgID') && helpers.isRequiredField(raw, 'revokeTime') && helpers.isRequiredField(raw, 'sessionType') && helpers.isRequiredField(raw, 'seq')) {
    return { revokerID: helpers.readStringParam(raw, 'revokerID'), revokerRole: helpers.readNumberParam(raw, 'revokerRole'), clientMsgID: helpers.readStringParam(raw, 'clientMsgID'), revokerNickname: helpers.readStringParam(raw, 'revokerNickname'), revokeTime: helpers.readNumberParam(raw, 'revokeTime'), sourceMessageSendTime: helpers.readNumberParam(raw, 'sourceMessageSendTime'), sourceMessageSendID: helpers.readStringParam(raw, 'sourceMessageSendID'), sourceMessageSenderNickname: helpers.readStringParam(raw, 'sourceMessageSenderNickname'), sessionType: helpers.readNumberParam(raw, 'sessionType') as OpenIMSessionType, seq: helpers.readNumberParam(raw, 'seq'), ex: helpers.readStringParam(raw, 'ex'), isAdminRevoke: helpers.readBooleanParam(raw, 'isAdminRevoke') }
  }
  return null
}

function parseNativeMessageReceiptItem(item : UTSJSONObject, helpers : NativeParserHelpers) : OpenIMMessageReceiptItem {
  return { groupID: helpers.readStringParam(item, 'groupID'), userID: helpers.readStringParam(item, 'userID'), msgIDList: parseNativeStringList(readNativeValue(item, 'msgIDList'), helpers), readTime: helpers.readNumberParam(item, 'readTime'), msgFrom: helpers.readNumberParam(item, 'msgFrom'), contentType: helpers.readNumberParam(item, 'contentType') as OpenIMMessageType, sessionType: helpers.readNumberParam(item, 'sessionType') as OpenIMSessionType }
}

export function parseNativeMessageReceiptListCommon(data : string, helpers : NativeParserHelpers) : OpenIMMessageReceiptListResult | null {
  const rawList = helpers.parseNativeJSONObjectListData(data)
  if (rawList == null) { return null }
  const receipts : Array<OpenIMMessageReceiptItem> = []
  let valid = true
  rawList.forEach((item : UTSJSONObject) => { if (helpers.isRequiredField(item, 'userID') && helpers.isRequiredField(item, 'readTime') && helpers.isRequiredField(item, 'contentType') && helpers.isRequiredField(item, 'sessionType')) { receipts.push(parseNativeMessageReceiptItem(item, helpers)) } else { valid = false } })
  if (valid == false) { return null }
  return { receipts: receipts }
}

export function parseNativeLoginStatusCommon(data : string) : OpenIMLoginStatus {
  if (data == '3') { return 3 }
  if (data == '2') { return 2 }
  return 1
}
