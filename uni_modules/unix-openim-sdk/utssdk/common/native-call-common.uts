export type NativeParserHelpers = {
  parseNativeAny : (data : string) => any | null,
  parseNativeJSONObjectListData : (data : string) => Array<UTSJSONObject> | null,
  parseNativeConversationItemData : (data : string) => OpenIMConversationItem | null,
  parseNativeConversationListData : (data : string) => Array<OpenIMConversationItem> | null,
  parseNativeUserInfoData : (data : string) => OpenIMUserInfo | null,
  parseNativeUserInfoListData : (data : string) => Array<OpenIMUserInfo> | null,
  parseNativeFriendUserListData : (data : string) => Array<OpenIMFriendUserItem> | null,
  parseNativeBlackUserListData : (data : string) => Array<OpenIMBlackUserItem> | null,
  parseNativeGroupData : (data : string) => OpenIMGroupItem | null,
  parseNativeGroupListData : (data : string) => Array<OpenIMGroupItem> | null,
  parseNativeGroupMemberListData : (data : string) => Array<OpenIMGroupMemberItem> | null,
  parseNativeFriendApplicationListData : (data : string) => Array<OpenIMFriendApplicationItem> | null,
  parseNativeGroupApplicationListData : (data : string) => Array<OpenIMGroupApplicationItem> | null,
  parseNativeMessageData : (data : string) => OpenIMMessageItem | null,
  parseNativeMessageListData : (data : string) => Array<OpenIMMessageItem> | null,
  parseNativeAdvancedHistoryMessageListData : (data : string) => OpenIMAdvancedHistoryMessageListResult | null,
  parseNativeStringListData : (data : string) => Array<string> | null,
  readStringParam : (value : any | null, key : string) => string,
  readNumberParam : (value : any | null, key : string) => number,
  readBooleanParam : (value : any | null, key : string) => boolean,
  isRequiredField : (value : UTSJSONObject, key : string) => boolean,
  isOptionalNumberField : (value : UTSJSONObject, key : string) => boolean
}

export function normalizeOperationID(operationID ?: string | null) : string {
  return operationID != null ? operationID : ''
}

export function stringifyJSON(value : any | null) : string {
  const text = JSON.stringify(value)
  if (text != null) {
    return text as string
  }
  return '{}'
}

export function buildJSONField(key : string, value : string) : string {
  return '"' + key + '":' + value
}

export function stringifyJSONString(value : string | null) : string {
  if (value == null) { return 'null' }
  const text = JSON.stringify(value)
  if (text != null) { return text as string }
  return '""'
}

export function stringifyJSONNumber(value : number) : string {
  return value.toString()
}

export function stringifyJSONBoolean(value : boolean) : string {
  return value ? 'true' : 'false'
}

export function appendJSONText(json : string, field : string) : string {
  return json.length == 0 ? field : json + ',' + field
}

export function appendOptionalJSONStringText(json : string, key : string, value ?: string | null) : string {
  if (value != null) { return appendJSONText(json, buildJSONField(key, stringifyJSONString(value as string))) }
  return json
}

export function appendOptionalJSONNumberText(json : string, key : string, value ?: number | null) : string {
  if (value != null) { return appendJSONText(json, buildJSONField(key, stringifyJSONNumber(value as number))) }
  return json
}

export function appendOptionalJSONBooleanText(json : string, key : string, value ?: boolean | null) : string {
  if (value != null) { return appendJSONText(json, buildJSONField(key, stringifyJSONBoolean(value as boolean))) }
  return json
}

export function stringifyStringList(value ?: Array<string> | null) : string {
  if (value == null) { return '[]' }
  const list = value as Array<string>
  let text = ''
  list.forEach((item : string) => { text = appendJSONText(text, stringifyJSONString(item)) })
  return '[' + text + ']'
}

export function stringifyOpenIMMessageEntityList(value ?: Array<OpenIMMessageEntity> | null) : string {
  if (value == null) { return '[]' }
  const list = value as Array<OpenIMMessageEntity>
  let text = ''
  list.forEach((entity : OpenIMMessageEntity) => {
    let item = ''
    item = appendOptionalJSONStringText(item, 'type', entity.type)
    item = appendOptionalJSONNumberText(item, 'offset', entity.offset)
    item = appendOptionalJSONNumberText(item, 'length', entity.length)
    item = appendOptionalJSONStringText(item, 'url', entity.url)
    item = appendOptionalJSONStringText(item, 'ex', entity.ex)
    item = appendOptionalJSONStringText(item, 'info', entity.info)
    text = appendJSONText(text, '{' + item + '}')
  })
  return '[' + text + ']'
}

export function rejectNativeError(reject : (reason : any | null) => void, errCode : number, errMsg : string) {
  const error = {
    errCode: errCode,
    errMsg: errMsg
  }
  reject(error)
}

export function hasNativeKey(value : UTSJSONObject, key : string) : boolean {
  const keys = UTSJSONObject.keys(value)
  let index = 0
  while (index < keys.length) {
    if (keys[index] == key) {
      return true
    }
    index = index + 1
  }
  return false
}

export function readNativeValue(value : any | null, key : string) : any | null {
  if (value instanceof UTSJSONObject && hasNativeKey(value, key)) {
    return value[key]
  }
  return null
}

function stringifyNativeValue(value : any | null) : string | null {
  if (value != null) {
    const text = JSON.stringify(value)
    if (text != null) { return text as string }
  }
  return null
}

function parseObjectFromValue(value : any | null, helpers : NativeParserHelpers) : UTSJSONObject | null {
  const text = stringifyNativeValue(value)
  if (text == null) { return null }
  const raw = helpers.parseNativeAny(text)
  if (raw instanceof UTSJSONObject) { return raw }
  return null
}

export function parseNativeUploadFileResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMUploadFileResult | null {
  const raw = helpers.parseNativeAny(data)
  if (raw instanceof UTSJSONObject) {
    return { url: helpers.readStringParam(raw, 'url'), uri: helpers.readStringParam(raw, 'uri'), uuid: helpers.readStringParam(raw, 'uuid'), size: helpers.readNumberParam(raw, 'size'), typ: helpers.readNumberParam(raw, 'typ'), mediaID: helpers.readStringParam(raw, 'mediaID') }
  }
  return null
}

export function parseNativeUploadFileProgressEventCommon(data : string, helpers : NativeParserHelpers) : OpenIMUploadFileProgressEvent | null {
  const raw = helpers.parseNativeAny(data)
  if (raw instanceof UTSJSONObject) {
    return { progress: helpers.readNumberParam(raw, 'progress') }
  }
  return null
}

export function parseNativeUploadLogsProgressEventCommon(data : string, helpers : NativeParserHelpers) : OpenIMUploadLogsProgressEvent | null {
  const raw = helpers.parseNativeAny(data)
  if (raw instanceof UTSJSONObject) {
    return { progress: helpers.readNumberParam(raw, 'progress') }
  }
  return null
}

function parseNativeConversationItem(item : UTSJSONObject, helpers : NativeParserHelpers) : OpenIMConversationItem {
  return {
    conversationID: helpers.readStringParam(item, 'conversationID'),
    conversationType: helpers.readNumberParam(item, 'conversationType') as OpenIMSessionType,
    userID: helpers.readStringParam(item, 'userID'),
    groupID: helpers.readStringParam(item, 'groupID'),
    showName: helpers.readStringParam(item, 'showName'),
    faceURL: helpers.readStringParam(item, 'faceURL'),
    recvMsgOpt: helpers.readNumberParam(item, 'recvMsgOpt'),
    unreadCount: helpers.readNumberParam(item, 'unreadCount'),
    latestMsg: helpers.readStringParam(item, 'latestMsg'),
    latestMsgSendTime: helpers.readNumberParam(item, 'latestMsgSendTime'),
    draftText: helpers.readStringParam(item, 'draftText'),
    draftTextTime: helpers.readNumberParam(item, 'draftTextTime'),
    isPinned: helpers.readBooleanParam(item, 'isPinned'),
    isPrivateChat: helpers.readBooleanParam(item, 'isPrivateChat'),
    attachedInfo: helpers.readStringParam(item, 'attachedInfo'),
    ex: helpers.readStringParam(item, 'ex'),
    burnDuration: helpers.readNumberParam(item, 'burnDuration'),
    minSeq: helpers.readNumberParam(item, 'minSeq'),
    maxSeq: helpers.readNumberParam(item, 'maxSeq'),
    msgDestructTime: helpers.readNumberParam(item, 'msgDestructTime'),
    groupAtType: helpers.readNumberParam(item, 'groupAtType'),
    isMsgDestruct: helpers.readBooleanParam(item, 'isMsgDestruct'),
    isNotInGroup: helpers.readBooleanParam(item, 'isNotInGroup'),
    updateUnreadCountTime: helpers.readNumberParam(item, 'updateUnreadCountTime')
  }
}

function isValidParsedConversation(conversation : OpenIMConversationItem, helpers : NativeParserHelpers) : boolean {
  const raw = parseObjectFromValue(conversation, helpers)
  if (raw == null) { return false }
  return helpers.isRequiredField(raw, 'conversationType') &&
    helpers.isRequiredField(raw, 'recvMsgOpt') &&
    helpers.isRequiredField(raw, 'unreadCount') &&
    helpers.isRequiredField(raw, 'latestMsgSendTime') &&
    helpers.isRequiredField(raw, 'draftTextTime') &&
    helpers.isRequiredField(raw, 'burnDuration') &&
    helpers.isRequiredField(raw, 'minSeq') &&
    helpers.isRequiredField(raw, 'maxSeq') &&
    helpers.isRequiredField(raw, 'msgDestructTime') &&
    helpers.isRequiredField(raw, 'groupAtType') &&
    helpers.isRequiredField(raw, 'updateUnreadCountTime')
}

function isValidParsedConversationList(conversations : Array<OpenIMConversationItem>, helpers : NativeParserHelpers) : boolean {
  let index = 0
  while (index < conversations.length) {
    if (isValidParsedConversation(conversations[index], helpers) == false) { return false }
    index = index + 1
  }
  return true
}

function parseNativeConversationListFallback(data : string, helpers : NativeParserHelpers) : Array<OpenIMConversationItem> | null {
  const rawList = helpers.parseNativeJSONObjectListData(data)
  if (rawList == null) { return null }
  const conversations : Array<OpenIMConversationItem> = []
  rawList.forEach((item : UTSJSONObject) => { conversations.push(parseNativeConversationItem(item, helpers)) })
  return conversations
}

function parseNativeConversationList(data : string, helpers : NativeParserHelpers) : Array<OpenIMConversationItem> | null {
  const typedList = helpers.parseNativeConversationListData(data)
  if (typedList != null) { return typedList }
  return parseNativeConversationListFallback(data, helpers)
}

export function parseNativeConversationEventListCommon(data : string, helpers : NativeParserHelpers) : OpenIMConversationListResult | null {
  const conversations = parseNativeConversationList(data, helpers)
  if (conversations == null) { return null }
  if (isValidParsedConversationList(conversations, helpers) == false) { return null }
  return { conversations: conversations }
}

export function parseNativeConversationObjectCommon(data : string, helpers : NativeParserHelpers) : OpenIMConversationItem | null {
  const typedItem = helpers.parseNativeConversationItemData(data)
  if (typedItem != null && isValidParsedConversation(typedItem, helpers)) { return typedItem }
  const raw = helpers.parseNativeAny(data)
  if (raw instanceof UTSJSONObject) { return parseNativeConversationItem(raw, helpers) }
  return null
}

export function parseNativeConversationListResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMConversationListResult | null {
  const conversations = parseNativeConversationList(data, helpers)
  if (conversations != null) { return { conversations: conversations } }
  return null
}

export function parseNativeConversationListResultFallbackCommon(data : string, helpers : NativeParserHelpers) : OpenIMConversationListResult | null {
  const conversations = parseNativeConversationListFallback(data, helpers)
  if (conversations != null && isValidParsedConversationList(conversations, helpers)) { return { conversations: conversations } }
  return null
}

function parseNativeUserItem(item : UTSJSONObject, helpers : NativeParserHelpers) : OpenIMUserInfo {
  return {
    userID: helpers.readStringParam(item, 'userID'),
    nickname: helpers.readStringParam(item, 'nickname'),
    faceURL: helpers.readStringParam(item, 'faceURL'),
    ex: helpers.readStringParam(item, 'ex'),
    createTime: helpers.readNumberParam(item, 'createTime'),
    attachedInfo: helpers.readStringParam(item, 'attachedInfo'),
    globalRecvMsgOpt: helpers.readNumberParam(item, 'globalRecvMsgOpt')
  }
}

function isValidParsedUser(user : OpenIMUserInfo, helpers : NativeParserHelpers) : boolean {
  const raw = parseObjectFromValue(user, helpers)
  if (raw == null) { return false }
  return helpers.isOptionalNumberField(raw, 'createTime') && helpers.isOptionalNumberField(raw, 'globalRecvMsgOpt')
}

function isValidParsedUserList(users : Array<OpenIMUserInfo>, helpers : NativeParserHelpers) : boolean {
  let index = 0
  while (index < users.length) {
    if (isValidParsedUser(users[index], helpers) == false) { return false }
    index = index + 1
  }
  return true
}

export function parseNativeUserListResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMUserListResult | null {
  const typedList = helpers.parseNativeUserInfoListData(data)
  if (typedList != null && isValidParsedUserList(typedList, helpers)) { return { users: typedList } }
  const rawList = helpers.parseNativeJSONObjectListData(data)
  if (rawList == null) { return null }
  const users : Array<OpenIMUserInfo> = []
  rawList.forEach((item : UTSJSONObject) => { users.push(parseNativeUserItem(item, helpers)) })
  return { users: users }
}

function parseNativeNumberListValue(value : any | null) : Array<number> {
  const text = stringifyNativeValue(value)
  if (text == null) { return [] }
  const trimmed = text.trim()
  if (trimmed.length < 2) { return [] }
  const body = trimmed.substring(1, trimmed.length - 1)
  if (body.length == 0) { return [] }
  const result : Array<number> = []
  const items = body.split(',')
  items.forEach((item : string) => { result.push(parseFloat(item.trim())) })
  return result
}

function parseNativeUserStatusItem(item : UTSJSONObject, helpers : NativeParserHelpers) : OpenIMUserStatusItem {
  return { userID: helpers.readStringParam(item, 'userID'), status: helpers.readNumberParam(item, 'status'), platformIDs: parseNativeNumberListValue(readNativeValue(item, 'platformIDs')) }
}

export function parseNativeUserStatusListResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMUserStatusListResult | null {
  const rawList = helpers.parseNativeJSONObjectListData(data)
  if (rawList == null) { return null }
  const statuses : Array<OpenIMUserStatusItem> = []
  rawList.forEach((item : UTSJSONObject) => { statuses.push(parseNativeUserStatusItem(item, helpers)) })
  return { statuses: statuses }
}

export function parseNativeUserObjectCommon(data : string, helpers : NativeParserHelpers) : OpenIMUserInfo | null {
  const typedItem = helpers.parseNativeUserInfoData(data)
  if (typedItem != null && isValidParsedUser(typedItem, helpers)) { return typedItem }
  const raw = helpers.parseNativeAny(data)
  if (raw instanceof UTSJSONObject && helpers.isRequiredField(raw, 'userID')) { return parseNativeUserItem(raw, helpers) }
  return null
}

export function parseNativeUserStatusEventListCommon(data : string, helpers : NativeParserHelpers) : OpenIMUserStatusListResult | null {
  const rawList = helpers.parseNativeJSONObjectListData(data)
  if (rawList == null) { return null }
  const statuses : Array<OpenIMUserStatusItem> = []
  let valid = true
  rawList.forEach((item : UTSJSONObject) => {
    if (helpers.isRequiredField(item, 'userID') && helpers.isRequiredField(item, 'status')) { statuses.push(parseNativeUserStatusItem(item, helpers)) } else { valid = false }
  })
  if (valid == false) { return null }
  return { statuses: statuses }
}

function parseNativeFriendItem(item : UTSJSONObject, helpers : NativeParserHelpers) : OpenIMFriendUserItem {
  return { ownerUserID: helpers.readStringParam(item, 'ownerUserID'), userID: helpers.readStringParam(item, 'userID'), nickname: helpers.readStringParam(item, 'nickname'), faceURL: helpers.readStringParam(item, 'faceURL'), remark: helpers.readStringParam(item, 'remark'), createTime: helpers.readNumberParam(item, 'createTime'), addSource: helpers.readNumberParam(item, 'addSource'), operatorUserID: helpers.readStringParam(item, 'operatorUserID'), ex: helpers.readStringParam(item, 'ex'), attachedInfo: helpers.readStringParam(item, 'attachedInfo'), isPinned: helpers.readBooleanParam(item, 'isPinned') }
}

function isValidParsedFriendList(friends : Array<OpenIMFriendUserItem>, helpers : NativeParserHelpers) : boolean {
  let index = 0
  while (index < friends.length) {
    const raw = parseObjectFromValue(friends[index], helpers)
    if (raw == null || helpers.isRequiredField(raw, 'createTime') == false || helpers.isRequiredField(raw, 'addSource') == false) { return false }
    index = index + 1
  }
  return true
}

export function parseNativeFriendListResultCommon(data : string, helpers : NativeParserHelpers) : OpenIMFriendListResult | null {
  const typedList = helpers.parseNativeFriendUserListData(data)
  if (typedList != null && isValidParsedFriendList(typedList, helpers)) { return { friends: typedList } }
  return parseNativeFriendListResultFallbackCommon(data, helpers)
}

export function parseNativeFriendListResultFallbackCommon(data : string, helpers : NativeParserHelpers) : OpenIMFriendListResult | null {
  const rawList = helpers.parseNativeJSONObjectListData(data)
