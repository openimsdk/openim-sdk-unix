function isValidParsedMessageObject(raw : UTSJSONObject, helpers : NativeParserHelpers) : boolean {
  return helpers.isRequiredField(raw, 'createTime') && helpers.isRequiredField(raw, 'sendTime') && helpers.isRequiredField(raw, 'sessionType') && helpers.isRequiredField(raw, 'msgFrom') && helpers.isRequiredField(raw, 'contentType') && helpers.isRequiredField(raw, 'senderPlatformID') && helpers.isRequiredField(raw, 'seq') && helpers.isRequiredField(raw, 'status')
}

function isValidParsedMessage(message : OpenIMMessageItem, helpers : NativeParserHelpers) : boolean {
  const raw = parseObjectFromValue(message, helpers)
  if (raw == null) { return false }
  return isValidParsedMessageObject(raw, helpers)
}

function isValidParsedMessageList(messages : Array<OpenIMMessageItem>, helpers : NativeParserHelpers) : boolean {
  let index = 0
  while (index < messages.length) {
    if (isValidParsedMessage(messages[index], helpers) == false) { return false }
    index = index + 1
  }
  return true
}

export function parseNativeMessageCommon(data : string, helpers : NativeParserHelpers) : OpenIMMessageItem | null {
  const trimmed = data.trim()
  if (trimmed.length == 0) { return null }
  const firstChar = trimmed.substring(0, 1)
  if (firstChar == '[') {
    const typedList = helpers.parseNativeMessageListData(trimmed)
    if (typedList != null && typedList.length > 0 && isValidParsedMessage(typedList[0], helpers)) { return typedList[0] }
    const rawList = helpers.parseNativeJSONObjectListData(trimmed)
    if (rawList != null && rawList.length > 0 && isValidParsedMessageObject(rawList[0], helpers)) { return parseNativeMessageItem(rawList[0], helpers) }
    return null
  }
  const typedMessage = helpers.parseNativeMessageData(trimmed)
  if (typedMessage != null && isValidParsedMessage(typedMessage, helpers)) { return typedMessage }
  const raw = helpers.parseNativeAny(trimmed)
  if (raw instanceof UTSJSONObject && isValidParsedMessageObject(raw, helpers)) { return parseNativeMessageItem(raw, helpers) }
  return null
}

export function parseNativeAdvancedHistoryMessageListCommon(data : string, helpers : NativeParserHelpers) : OpenIMAdvancedHistoryMessageListResult | null {
  const typedResult = helpers.parseNativeAdvancedHistoryMessageListData(data)
  if (typedResult != null && isValidParsedMessageList(typedResult.messageList, helpers)) { return typedResult }
  return parseNativeAdvancedHistoryMessageListFallbackCommon(data, helpers)
}

export function parseNativeAdvancedHistoryMessageListFallbackCommon(data : string, helpers : NativeParserHelpers) : OpenIMAdvancedHistoryMessageListResult | null {
  const raw = helpers.parseNativeAny(data)
  if (!(raw instanceof UTSJSONObject)) { return null }
  const messages : Array<OpenIMMessageItem> = []
  const rawList = parseNativeJSONObjectList(readNativeValue(raw, 'messageList'), helpers)
  rawList.forEach((item : UTSJSONObject) => { if (isValidParsedMessageObject(item, helpers)) { messages.push(parseNativeMessageItem(item, helpers)) } })
  return { messageList: messages, isEnd: helpers.readBooleanParam(raw, 'isEnd'), errCode: helpers.readNumberParam(raw, 'errCode'), errMsg: helpers.readStringParam(raw, 'errMsg') }
}

function parseNativeMessageListFromValue(value : any | null, helpers : NativeParserHelpers) : Array<OpenIMMessageItem> {
  const messages : Array<OpenIMMessageItem> = []
  const rawList = parseNativeJSONObjectList(value, helpers)
  rawList.forEach((item : UTSJSONObject) => { messages.push(parseNativeMessageItem(item, helpers)) })
  return messages
}

export function parseNativeMessageEventListCommon(data : string, helpers : NativeParserHelpers) : OpenIMMessageListResult | null {
  const typedList = helpers.parseNativeMessageListData(data)
  if (typedList != null && isValidParsedMessageList(typedList, helpers)) { return { messages: typedList } }
  return parseNativeMessageEventListFallbackCommon(data, helpers)
